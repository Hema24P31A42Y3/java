ublic class secondlarger{
    public static void main(String args[]){
        int a[]={1,2,3,4,5,6};
        int larger =a[0];
        int secondlarger =a[0];
        for(int i =0;i<a.length;i++){
            if(a[i]>larger){
                secondlarger=larger;
                larger=a[i];
            }
            else if(a[i]>secondlarger){
                secondlarger=a[i];
            }
        }
        System.out.println("secondlarger="+secondlarger);
    }
}
